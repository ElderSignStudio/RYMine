# Copy this file to `.env` and edit. `.env` is gitignored.

# ── App mode ───────────────────────────────────────────────────────────────
# `local`    — full read/write personality. Bookmarklets, imports, full sync,
#              enrichment all work. No login required. Default.
# `readonly` — browse-only viewer. Requires a password (below). All write
#              endpoints reject with 403. Use for hosted instances.
RYMINE_MODE=local

# Password for the readonly viewer login. Required (and only used) when
# RYMINE_MODE=readonly — the server refuses to boot in readonly mode without
# one. Changing the value invalidates all outstanding sessions immediately
# (the session cookie is keyed by this password).
RYMINE_VIEWER_PASSWORD=

# ── Publish channel ────────────────────────────────────────────────────────
# Shared secret that gates POST /api/publish. The local writable instance
# sends it as `Authorization: Bearer <token>`; the hosted readonly instance
# verifies it constant-time. Must match on BOTH sides for publish to work.
# (Different from RYMINE_VIEWER_PASSWORD — that's the human login.)
RYMINE_PUBLISH_TOKEN=

# Local-only: the full URL of the hosted readonly's /api/publish endpoint.
# When set together with RYMINE_PUBLISH_TOKEN on a `RYMINE_MODE=local`
# instance, the "Publish" button appears in the header. Leave blank on the
# hosted readonly instance.
# RYMINE_PUBLISH_URL=https://my-rymine-viewer.example.com/api/publish

# ── Data file location ────────────────────────────────────────────────────
# Where the wishlist JSON is read/written. Optional. Defaults to the in-repo
# path `./data/wishlist.json`. Set this to an absolute path when running on
# a host that exposes a persistent disk mount (e.g. Render disks):
#   RYMINE_DATA_PATH=/var/data/wishlist.json
# Relative paths resolve against the process cwd. The directory is created
# automatically if missing.
# RYMINE_DATA_PATH=

# ── Production server (adapter-node) ──────────────────────────────────────
# These are only relevant when hosting (e.g. Render). Locally, `npm start`
# falls back to 127.0.0.1:3000. On Render, set:
#   PORT     — Render injects this automatically; do NOT override.
#   HOST     — bind address. On Render, use 0.0.0.0.
#   ORIGIN   — the public URL of your service. REQUIRED for SvelteKit's
#              CSRF check to accept form posts (login, publish-from-local).
#              Example: https://my-rymine-viewer.onrender.com
#   BODY_SIZE_LIMIT — adapter-node's request size cap (default 524288 bytes
#              ≈ 512 KB). Raise this to comfortably exceed your wishlist
#              JSON size for /api/publish. 5MB is plenty:
#                BODY_SIZE_LIMIT=5000000
# HOST=0.0.0.0
# ORIGIN=https://my-rymine-viewer.onrender.com
# BODY_SIZE_LIMIT=5000000

# ── RYM scraper config (only consumed by the local-mode workflows) ─────────
# The full URL of your Rate Your Music wishlist (the page you visit in a
# browser after logging in). Examples (your actual URL may differ):
#   https://rateyourmusic.com/collection/<username>/wl/
#   https://rateyourmusic.com/wishlist/<username>
RYM_WISHLIST_URL=https://rateyourmusic.com/collection/Flict/wishlist

# Optional: page the login flow opens first. Defaults to https://rateyourmusic.com/
# RYM_LOGIN_URL=https://rateyourmusic.com/account/login

# Optional: use your installed real Chrome instead of Playwright's bundled
# Chromium. Setting this to "chrome" is the most human-like option for getting
# past Cloudflare's "are you human" check, but requires Google Chrome to be
# installed locally. Valid values: chrome | chrome-beta | msedge | msedge-beta
# RYM_BROWSER_CHANNEL=chrome

# Optional knobs (all have sensible defaults)
# RYM_HEADLESS=false            # default false so you can solve any Cloudflare
#                                 challenge interactively. Flip to true once
#                                 the profile is warm and you've confirmed
#                                 scrapes go through cleanly.
# RYM_MIN_DELAY_MS=3500         # min ms between page navigations
# RYM_MAX_DELAY_MS=7500         # max ms between page navigations
# RYM_MAX_PAGES=100             # safety cap on pagination
# RYM_CHALLENGE_WAIT_MS=120000  # how long to wait for you to solve an
#                                 interactive Cloudflare challenge mid-scrape
# RYM_DEBUG=false               # dumps each page's HTML to data/debug/
